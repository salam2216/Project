{
  "info": {
    "_postman_id": "a1463f56-2c2b-4a9f-97d8-94adf0f65a80",
    "name": "SCALA-Guard Backend API",
    "description": "Postman collection for SCALA-Guard backend endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000"
    },
    {
      "key": "packageName",
      "value": "requests"
    },
    {
      "key": "ecosystem",
      "value": "pypi"
    },
    {
      "key": "scanText",
      "value": "detected requests-fake and possible outbound connection"
    },
    {
      "key": "scanId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response has API name', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('name');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Health status is ok', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('status', 'ok');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Analyze Uploaded File (PDF/DOC/DOCX/CSV/Archive)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "package_file",
              "type": "file",
              "src": ""
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/analyze",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "analyze"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Analyze response has risk block', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('risk');",
              "  pm.expect(body.risk).to.have.property('score');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Analyze by Name",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"{{packageName}}\",\n  \"version\": \"latest\",\n  \"ecosystem\": \"{{ecosystem}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/analyze/name",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "analyze",
            "name"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Response includes package_name', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('package_name');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Analyze Text",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"{{scanText}}\",\n  \"ecosystem\": \"{{ecosystem}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/analyze/text",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "analyze",
            "text"
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.test('Text analyze returns scan id', function () {",
              "  const body = pm.response.json();",
              "  pm.expect(body).to.have.property('scan_id');",
              "  pm.collectionVariables.set('scanId', body.scan_id);",
              "});"
            ]
          }
        }
      ]
    },
